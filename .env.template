# Hermes migration / server rebuild template
#
# Copy this to ~/.hermes/.env on the new server and fill in real values.
# Keep the real file out of git.
#
# This file is migration-focused. It reflects the keys discovered on the current
# server, not every upstream Hermes env variable.

# =============================================================================
# TELEGRAM / GATEWAY
# =============================================================================
# Reuse the same bot token if you want the new server to take over the existing
# Telegram bot identity. Stop the old gateway before starting the new one.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_HOME_CHANNEL=

# =============================================================================
# WEB / RESEARCH TOOLS
# =============================================================================
TAVILY_API_KEY=
FIRECRAWL_API_KEY=
HUNTER_API_KEY=
APOLLO_API_KEY=
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=

# =============================================================================
# AIRTABLE / DATA STORES
# =============================================================================
AIRTABLE_PAT=
AIRTABLE_WORKSPACE_ID=
AIRTABLE_BASE_ID=
AIRTABLE_FLIGHTS_TABLE=
AIRTABLE_PADEL_BASE_ID=
AIRTABLE_PADEL_TABLE_ID=

# =============================================================================
# GITHUB / DEV TOOLS
# =============================================================================
GITHUB_TOKEN=

# =============================================================================
# FGBUDDY / SUPABASE
# =============================================================================
FGBUDDY_PROFILE_ID=
FGBUDDY_UNKNOWN_WALLET_ID=
FGBUDDY_SUPABASE_URL=
FGBUDDY_SUPABASE_KEY=
FGBUDDY_TX_WEBHOOK_SECRET=

# =============================================================================
# OPTIONAL FALLBACK MODEL KEYS
# =============================================================================
# These were not discovered as active keys here, but are common Hermes fallback
# provider keys if you intentionally use them on the new server.
OPENROUTER_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=

# =============================================================================
# NOTES
# =============================================================================
# - Many Hermes settings live in ~/.hermes/config.yaml, not in .env.
# - OAuth/device-code auth can also live in ~/.hermes/auth.json.
# - Restoring a full Hermes backup may also restore ~/.hermes/.env.
# - If you restore from backup and also want to inject a fresh env file, copy
#   the env file after import so the backup does not overwrite it.
